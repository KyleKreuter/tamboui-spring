<t:dock xmlns:t="https://github.com/KyleKreuter/tamboui-spring/template"
        top-height="3" bottom-height="3">

  <!-- Top: Tabs navigation -->
  <t:tabs region="top" bind="navigationTabs" titles="Overview,Editor,Forms"
          title="${title}" highlight-color="cyan"
          border-type="rounded" border-color="cyan" />

  <!-- Center: Main content area -->
  <t:grid region="center" grid-columns="2" grid-rows="1" gutter="1">

    <!-- TextArea widget -->
    <t:panel title="TextArea" class="border-rounded">
      <t:textarea bind="editorState" title="Code Editor"
                  border-type="rounded"
                  focused-border-color="cyan" show-line-numbers="true"
                  placeholder="Start typing..." />
    </t:panel>

    <!-- FormField widgets -->
    <t:panel title="FormField" class="border-rounded">
      <t:column spacing="1">
        <t:form-field label="Search" bind="searchInput"
                      placeholder="Type to search..."
                      border-type="rounded" border-color="dark-gray"
                      focused-border-color="cyan" label-width="12" />
        <t:form-field label="Dark Mode" bind="darkModeToggle"
                      type="toggle"
                      border-type="rounded" border-color="dark-gray" />
      </t:column>
    </t:panel>

  </t:grid>

  <!-- Bottom: Footer -->
  <t:panel region="bottom" class="border-rounded">
    <t:text t:text="${footerHint}" class="text-cyan" />
  </t:panel>

</t:dock>
