<t:dock xmlns:t="https://github.com/KyleKreuter/tamboui-spring/template"
        top-height="3" bottom-height="3" left-width="30">

  <t:panel region="top" title="User Management" class="border-rounded text-cyan">
    <t:text t:text="Users: ${userCount}  |  [a] Add  [r] Remove  [d] Details" class="text-yellow" />
  </t:panel>

  <t:panel region="left" title="User List" class="border-rounded">
    <t:if test="${hasUsers}">
      <t:list>
        <t:each items="${userLines}" var="line">
          <t:item t:text="${line}" />
        </t:each>
      </t:list>
    </t:if>
    <t:if test="${!hasUsers}">
      <t:text t:text="No users. Press [a] to add." class="dim" />
    </t:if>
  </t:panel>

  <t:column region="center" spacing="1">

    <t:if test="${hasUsers}">
      <t:panel title="Current User" class="border-rounded text-white">
        <t:column spacing="0">
          <t:text t:text="Name:   ${currentName}" class="bold" />
          <t:text t:text="Role:   ${currentRole}" />
          <t:if test="${currentActive}">
            <t:text t:text="Status: ${currentStatus}" class="text-green bold" />
          </t:if>
          <t:if test="${!currentActive}">
            <t:text t:text="Status: ${currentStatus}" class="text-red bold" />
          </t:if>
        </t:column>
      </t:panel>
    </t:if>

    <t:if test="${showDetails}">
      <t:panel title="Teams" class="border-rounded text-green">
        <t:list>
          <t:each items="${teams}" var="team">
            <t:item t:text="${team}" />
          </t:each>
        </t:list>
      </t:panel>
    </t:if>

  </t:column>

  <t:panel region="bottom" class="border-rounded">
    <t:text t:text="[1] Dashboard  [2] Users  [3] Settings  [a] Add  [r] Remove  [d] Details  [q] Quit" class="text-cyan" />
  </t:panel>

</t:dock>
