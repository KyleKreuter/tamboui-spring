<t:dock xmlns:t="https://github.com/KyleKreuter/tamboui-spring/template"
        top-height="3" bottom-height="3">

  <t:panel region="top" title="${title}" class="border-rounded text-cyan">
    <t:row spacing="4">
      <t:text t:text="${date}  ${time}" class="bold" />
      <t:text t:text="${languageLabel}:" />
      <t:select bind="languageSelect" />
    </t:row>
  </t:panel>

  <t:grid region="center" grid-columns="2" grid-rows="4" gutter="1">
    <t:panel title="${osLabel}" class="border-rounded">
      <t:text t:text="${osValue}" class="bold" />
    </t:panel>
    <t:panel title="${archLabel}" class="border-rounded">
      <t:text t:text="${archValue}" class="bold" />
    </t:panel>
    <t:panel title="${cpuLoadLabel}" class="border-rounded">
      <t:text t:text="${cpuLoadValue}" class="bold" />
    </t:panel>
    <t:panel title="${processorsLabel}" class="border-rounded">
      <t:text t:text="${processorsValue}" class="bold" />
    </t:panel>
    <t:panel title="${memoryLabel}" class="border-rounded">
      <t:text t:text="${memoryValue}" class="bold" />
    </t:panel>
    <t:panel title="${uptimeLabel}" class="border-rounded">
      <t:text t:text="${uptimeValue}" class="bold" />
    </t:panel>
    <t:panel title="${javaLabel}" class="border-rounded">
      <t:text t:text="${javaValue}" class="bold" />
    </t:panel>
    <t:panel title="${vmLabel}" class="border-rounded">
      <t:text t:text="${vmValue}" class="bold" />
    </t:panel>
  </t:grid>

  <t:panel region="bottom" class="border-rounded">
    <t:text t:text="${footerHint}" class="text-cyan" />
  </t:panel>

</t:dock>
