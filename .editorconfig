root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 4

[*.{xml,xsd,xsl}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,ttl}]
indent_style = space
indent_size = 2

[*.{properties,cfg}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.tcss]
indent_style = space
indent_size = 4

[mvnw]
end_of_line = lf

[mvnw.cmd]
end_of_line = crlf
